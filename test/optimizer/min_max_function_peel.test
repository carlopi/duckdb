# name: test/optimizer/min_max_function_peel.test
# description: Test MIN/MAX folding through invertible casts, monotonic function wrappers, and arithmetic operators
# group: [optimizer]

require no_alternative_verify

load {TEST_DIR}/peel.db

statement ok
CREATE TABLE t AS SELECT
  i::INTEGER AS bi,
  i::DOUBLE AS d,
  DATE '2020-01-01' + INTERVAL (i) DAY AS dt,
  TIMESTAMP '2020-01-01' + INTERVAL (i) HOUR AS ts
FROM range(2048) _(i)

restart

# Tier 1: single-arg monotonic wrapper
query II
EXPLAIN SELECT MIN(year(dt)), MAX(year(dt)) FROM t
----
physical_plan	<!REGEX>:.*UNGROUPED_AGGREGATE.*

query II
SELECT MIN(year(dt)), MAX(year(dt)) FROM t
----
2020	2025

# date_diff is Tier-2 (RequireFinite): stats-fold eliminates the aggregate for finite parquet/table data.
# Column at non-zero arg index (date_diff at idx 2).
query II
EXPLAIN SELECT MIN(date_diff('day', DATE '2020-01-01', dt)) FROM t
----
physical_plan	<!REGEX>:.*UNGROUPED_AGGREGATE.*

# date_diff with column on the start side folds via INVERTS_INPUT_ORDER on arg 1
query II
EXPLAIN SELECT MIN(date_diff('day', dt, DATE '2030-01-01')) FROM t
----
physical_plan	<!REGEX>:.*UNGROUPED_AGGREGATE.*

query I
SELECT MIN(date_diff('day', dt, DATE '2030-01-01')) FROM t
----
1606

# alias: bound function name carries the alias, so each alias is a separate entry
query II
EXPLAIN SELECT MIN(ceiling(d)) FROM t
----
physical_plan	<!REGEX>:.*UNGROUPED_AGGREGATE.*

# === arithmetic ===

# commutative + : column on either side
query II
EXPLAIN SELECT MIN(bi + 5), MIN(5 + bi) FROM t
----
physical_plan	<!REGEX>:.*UNGROUPED_AGGREGATE.*

query II
SELECT MIN(bi + 5), MIN(bi - 5) FROM t
----
5	-5

# date_add is lowered to dt + interval by the binder; covered by the + entry
query II
EXPLAIN SELECT MIN(date_add(dt, INTERVAL '7 day')) FROM t
----
physical_plan	<!REGEX>:.*UNGROUPED_AGGREGATE.*

# unary minus inverts ordering; folds via INVERTS_INPUT_ORDER + MIN/MAX swap
query II
EXPLAIN SELECT MIN(-bi), MAX(-bi) FROM t
----
physical_plan	<!REGEX>:.*UNGROUPED_AGGREGATE.*

query II
SELECT MIN(-bi), MAX(-bi) FROM t
----
-2047	0

# lit - col folds via INVERTS_INPUT_ORDER on arg 1 of binary -
query II
EXPLAIN SELECT MIN(5 - bi), MAX(5 - bi) FROM t
----
physical_plan	<!REGEX>:.*UNGROUPED_AGGREGATE.*

query II
SELECT MIN(5 - bi), MAX(5 - bi) FROM t
----
-2042	5

# === inversion parity through chained wrappers ===

# double negation cancels: parity even, MIN stays MIN
query II
EXPLAIN SELECT MIN(-(-bi)) FROM t
----
physical_plan	<!REGEX>:.*UNGROUPED_AGGREGATE.*

query I
SELECT MIN(-(-bi)) FROM t
----
0

# INVERTS composed with MATCHES: -(bi + 5) folds; MIN of -(bi+5) is achieved at MAX(bi)
query I
SELECT MIN(-(bi + 5)) FROM t
----
-2052

# === things deliberately not handled ===

# month / day / hour / etc. wrap modulo their period
query II
EXPLAIN SELECT MIN(month(dt)) FROM t
----
physical_plan	<REGEX>:.*UNGROUPED_AGGREGATE.*

# * and / have sign-dependent monotonicity (depends on the literal value)
query II
EXPLAIN SELECT MIN(d * 2.0) FROM t
----
physical_plan	<REGEX>:.*UNGROUPED_AGGREGATE.*

# both args are column refs → multiple non-foldable args → must NOT fold
query II
EXPLAIN SELECT MIN(bi - (bi + 1)) FROM t
----
physical_plan	<REGEX>:.*UNGROUPED_AGGREGATE.*

# === non-stats source: year() is Tier-2 only, so the aggregate stays for CSV sources ===

statement ok
COPY (SELECT
  i::INTEGER AS bi,
  DATE '2020-01-01' + INTERVAL (i) DAY AS dt
FROM range(2048) _(i)) TO '{TEST_DIR}/peel.csv' (FORMAT CSV, HEADER 1)

# year() is Tier-2 (RequireFinite); Tier-1 peel refuses it; CSV has no stats so aggregate stays.
query II
EXPLAIN SELECT MIN(year(dt)), MAX(year(dt)) FROM read_csv('{TEST_DIR}/peel.csv', auto_detect=true)
----
physical_plan	<REGEX>:.*UNGROUPED_AGGREGATE.*

query II
SELECT MIN(year(dt)), MAX(year(dt)) FROM read_csv('{TEST_DIR}/peel.csv', auto_detect=true)
----
2020	2025

# date_diff is also Tier-2; for CSV the aggregate stays (no stats to fold against).
query II
EXPLAIN SELECT MIN(date_diff('day', dt, DATE '2030-01-01')) FROM read_csv('{TEST_DIR}/peel.csv', auto_detect=true)
----
physical_plan	<REGEX>:.*UNGROUPED_AGGREGATE.*

query I
SELECT MIN(date_diff('day', dt, DATE '2030-01-01')) FROM read_csv('{TEST_DIR}/peel.csv', auto_detect=true)
----
1606

# multi-level chain: outer binary - is Tier-1 peelable; inner year() is Tier-2 (stays).
# The -5 wrapper is hoisted into a projection above MIN(year(dt)).
query II
EXPLAIN SELECT MIN(year(dt) - 5) FROM read_csv('{TEST_DIR}/peel.csv', auto_detect=true)
----
physical_plan	<REGEX>:.*UNGROUPED_AGGREGATE.*

query I
SELECT MIN(year(dt) - 5) FROM read_csv('{TEST_DIR}/peel.csv', auto_detect=true)
----
2015

# partial peel: outer unary - lifts (INVERTS, flips MIN->MAX); inner month is non-peelable and stays
query II
EXPLAIN SELECT MIN(-month(dt)) FROM read_csv('{TEST_DIR}/peel.csv', auto_detect=true)
----
physical_plan	<REGEX>:.*UNGROUPED_AGGREGATE.*Aggregates: max\(#0\).*

query I
SELECT MIN(-month(dt)) FROM read_csv('{TEST_DIR}/peel.csv', auto_detect=true)
----
-12

# === parquet source: rewrite + stats fold compose ===

require parquet

statement ok
COPY (SELECT
  i::INTEGER AS bi,
  DATE '2020-01-01' + INTERVAL (i) DAY AS dt
FROM range(2048) _(i)) TO '{TEST_DIR}/peel.parquet' (FORMAT PARQUET)

# full peel + stats fold: aggregate eliminated
query II
EXPLAIN SELECT MIN(year(dt)), MAX(year(dt)) FROM read_parquet('{TEST_DIR}/peel.parquet')
----
physical_plan	<!REGEX>:.*UNGROUPED_AGGREGATE.*

query II
SELECT MIN(year(dt)), MAX(year(dt)) FROM read_parquet('{TEST_DIR}/peel.parquet')
----
2020	2025

# partial peel on parquet: aggregate stays because the inner can't fold
query II
EXPLAIN SELECT MIN(-month(dt)) FROM read_parquet('{TEST_DIR}/peel.parquet')
----
physical_plan	<REGEX>:.*UNGROUPED_AGGREGATE.*Aggregates: max\(#0\).*

query I
SELECT MIN(-month(dt)) FROM read_parquet('{TEST_DIR}/peel.parquet')
----
-12

# === Tier-2 + stats-fold ===

require parquet

# Setup parquet table with FINITE date data — stats fold should fire for year().
statement ok
COPY (SELECT (DATE '2020-01-01' + INTERVAL (i) DAY)::DATE AS dt
      FROM range(2048) _(i)) TO '{TEST_DIR}/peel_finite.parquet' (FORMAT PARQUET)

# Stats fold: year(dt) over finite parquet -> aggregate eliminated, replaced by constant.
query II
EXPLAIN SELECT MIN(year(dt)) FROM read_parquet('{TEST_DIR}/peel_finite.parquet')
----
physical_plan	<!REGEX>:.*UNGROUPED_AGGREGATE.*

query I
SELECT MIN(year(dt)) FROM read_parquet('{TEST_DIR}/peel_finite.parquet')
----
2020

# Setup parquet table with infinity values -- stats fold must BAIL (year(infinity)=NULL).
statement ok
COPY (SELECT * FROM (VALUES
    ('2021-01-01'::DATE),
    ('infinity'::DATE),
    ('-infinity'::DATE)
) tbl(dt)) TO '{TEST_DIR}/peel_inf.parquet' (FORMAT PARQUET)

# Aggregate must remain (stats-fold bailed); per-row evaluation skips NULL year() outputs.
query II
EXPLAIN SELECT MAX(year(dt)) FROM read_parquet('{TEST_DIR}/peel_inf.parquet')
----
physical_plan	<REGEX>:.*UNGROUPED_AGGREGATE.*

query I
SELECT MAX(year(dt)) FROM read_parquet('{TEST_DIR}/peel_inf.parquet')
----
2021

# Same on read_csv (no stats at all): aggregate runs, year() per row.
statement ok
COPY (SELECT * FROM (VALUES
    ('2021-01-01'::DATE),
    ('infinity'::DATE),
    ('-infinity'::DATE)
) tbl(dt)) TO '{TEST_DIR}/peel_inf.csv' (FORMAT CSV, HEADER 1)

query I
SELECT MAX(year(dt)) FROM read_csv('{TEST_DIR}/peel_inf.csv', auto_detect=true)
----
2021
