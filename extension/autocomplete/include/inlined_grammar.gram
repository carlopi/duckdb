SetVariable <- VariableScope Identifier
VariableScope <- 'VARIABLE'

SettingScope <- LocalScope / SessionScope / GlobalScope
LocalScope <- 'LOKAL'
SessionScope <- 'SITZIG'
GlobalScope <- 'GLOBAL'

SetAssignment <- VariableAssign VariableList

VariableAssign <- '=' / 'ZU'
VariableList <- List(Expression)

ResetStatement <- 'ZRUGGSETZE' (SetVariable / SetSetting)

ExportStatement <- 'EXPORTIERE' 'DATEBANK' ExportSource? StringLiteral GenericCopyOptionList?

ExportSource <- CatalogName 'ZU'

ImportStatement <- 'IMPORTIERE' 'DATEBANK' StringLiteral

CheckpointStatement <- 'ZWINGE'? 'SICHERIGSPUNKT' CatalogName?

CopyStatement <- 'KOPIERE' (CopyTable / CopySelect / CopyFromDatabase)

CopyTable <- BaseTableName InsertColumnList? FromOrTo CopyFileName CopyOptions?
FromOrTo <- 'VO' / 'ZU'

CopySelect <- Parens(SelectStatementInternal) 'ZU' CopyFileName CopyOptions?

CopyFileName <- Parameter / ParensExpression / StringLiteral / Identifier / (Identifier '.' ColId)
CopyOptions <- 'MIT'? GenericCopyOptionList / SpecializedOptionList
SpecializedOptionList <- SpecializedOption*
SpecializedOption <- SingleOption / NullAsOption / DelimiterAsOption / EscapeAsOption /
	EncodingOption / QuoteAsOption / ForceQuoteOption / PartitionByOption / ForceNullOption

SingleOption <- BinaryOption / FreezeOption / OidsOption / CsvOption / HeaderOption
BinaryOption <- 'BINAER'
FreezeOption <- 'IIFRIERE'
OidsOption <- 'OIDS'
CsvOption <- 'CSV'
HeaderOption <- 'CHOPFZIILE'
NullAsOption <- 'NUET' 'ALS'? StringLiteral
DelimiterAsOption <- 'TRAENNZEICHE' 'ALS'? StringLiteral
QuoteAsOption <- 'AFUEEHRIGSZEICHE' 'ALS'? StringLiteral
EscapeAsOption <- 'FLUCHT' 'ALS'? StringLiteral
EncodingOption <- 'KODIERIG' StringLiteral
ForceQuoteOption <- 'ZWINGE'? 'AFUEEHRIGSZEICHE' (StarSymbol / ColumnList)
PartitionByOption <- 'UFTEILIG' 'NACH' (StarSymbol / ColumnList)
ForceNullOption <- 'ZWINGE' 'NID'? 'NUET' ColumnList
StarSymbol <- '*'

GenericCopyOptionList <- Parens(List(GenericCopyOption))
GenericCopyOption <- CopyOptionName Expression?

CopyFromDatabase <- 'VO' 'DATEBANK' ColId 'ZU' ColId CopyDatabaseFlag?

CopyDatabaseFlag <- Parens(SchemaOrData)
SchemaOrData <- CopySchema / CopyData
CopySchema <- 'SCHEMA'
CopyData <- 'DATE'

AlterStatement <- 'AENDERE' AlterOptions

AlterOptions <- AlterTableStmt / AlterViewStmt / AlterSequenceStmt / AlterDatabaseStmt / AlterSchemaStmt

AlterTableStmt <- 'TABAELLE' IfExists? BaseTableName AlterTableOptions
AlterSchemaStmt <- 'SCHEMA' IfExists? QualifiedName RenameAlter

AlterTableOptions <- AddColumn / DropColumn / AlterColumn / AddConstraint / ChangeNullability /
        RenameColumn / RenameAlter / SetPartitionedBy / ResetPartitionedBy / SetSortedBy / ResetSortedBy / SetOptions / ResetOptions

AddConstraint <- 'DEZUETUAE' TopLevelConstraint
AddColumn <- 'DEZUETUAE' 'SPALTE'? IfNotExists? AddColumnEntry
AddColumnEntry <- DottedIdentifier Type? GeneratedColumn? ColumnConstraint*
DropColumn <- 'ABESCHMISSE' 'SPALTE'? IfExists? NestedColumnName DropBehavior?
AlterColumn <- 'AENDERE' 'SPALTE'? NestedColumnName AlterColumnEntry
RenameColumn <- 'UMBENAENNE' 'SPALTE'? NestedColumnName 'ZU' Identifier
NestedColumnName <- (Identifier '.')* ColumnName
RenameAlter <- 'UMBENAENNE' 'ZU' Identifier
SetPartitionedBy <- 'SETZE' 'UFTEILT' 'NACH' Parens(List(Expression))
ResetPartitionedBy <- 'ZRUGGSETZE' 'UFTEILT' 'NACH'
SetSortedBy <- 'SETZE' 'SORTIERT' 'NACH' Parens(OrderByExpressions)
ResetSortedBy <- 'ZRUGGSETZE' 'SORTIERT' 'NACH'
SetOptions <- 'SETZE' RelOptionList
ResetOptions <- 'ZRUGGSETZE' RelOptionList

AlterColumnEntry <- AddOrDropDefault / ChangeNullability / AlterType

AddOrDropDefault <- AddDefault / DropDefault
AddDefault <- 'SETZE' 'STANDARD' Expression
DropDefault <- 'ABESCHMISSE' 'STANDARD'

ChangeNullability <- DropOrSet 'NID' 'NUET'
DropOrSet <- 'ABESCHMISSE' / 'SETZE'

AlterType <- SetData? 'TYP' Type? UsingExpression?
SetData <- 'SETZE' 'DATE'?
UsingExpression <- 'BRUUCHE' Expression

AlterViewStmt <- 'AASICHT' IfExists? BaseTableName RenameAlter

AlterSequenceStmt <- 'FOLG' IfExists? QualifiedSequenceName AlterSequenceOptions

QualifiedSequenceName <- CatalogQualification? SchemaQualification? SequenceName

AlterSequenceOptions <- RenameAlter / SetSequenceOption
SetSequenceOption <- List(SequenceOption)

AlterDatabaseStmt <- 'DATEBANK' IfExists? Identifier 'SETZE' 'ALIAS' 'ZU' Identifier

CreateSequenceStmt <- 'FOLG' IfNotExists? QualifiedName SequenceOption*

SequenceOption <-
	SeqSetCycle /
	SeqSetIncrement /
	SeqSetMinMax /
	SeqNoMinMax /
	SeqStartWith /
	SeqOwnedBy

SeqSetCycle <- 'KEI'? 'ZYKLUS'
SeqSetIncrement <- 'INKREMENT' 'NACH'? Expression
SeqSetMinMax <- SeqMinOrMax Expression
SeqNoMinMax <- 'KEI' SeqMinOrMax
SeqStartWith <- 'STARTE' 'MIT'? Expression
SeqOwnedBy <- 'BSITZT' 'NACH' QualifiedName

SeqMinOrMax <- MinValue / MaxValue
MinValue <- 'MINWAERT'
MaxValue <- 'MAXWAERT'
ExplainStatement <- 'ERCHLAERE' 'ANALYSIERE'? GenericCopyOptionList? ExplainableStatements

ExplainableStatements <-
    AlterStatement /
    AnalyzeStatement /
    CallStatement /
    CheckpointStatement /
    CopyStatement /
    CreateStatement /
    DeallocateStatement /
    DeleteStatement /
    DropStatement /
    ExecuteStatement /
    InsertStatement /
    LoadStatement /
    MergeIntoStatement /
    PragmaStatement /
    PrepareStatement /
    SelectStatementInternal /
    TransactionStatement /
    UpdateStatement /
    VacuumStatement /
    SetStatement /
    ResetStatement
AnalyzeStatement <- 'ANALYSIERE' 'USFUEHRLICH'? AnalyzeTarget?
AnalyzeTarget <- BaseTableName NameList?
CreateMacroStmt <- MacroOrFunction IfNotExists? QualifiedName List(MacroDefinition)

MacroOrFunction <- 'MAKRO' / 'FUNKTION'

MacroDefinition <- Parens(MacroParameters?) 'ALS' (TableMacroDefinition / ScalarMacroDefinition)

MacroParameters <- List(MacroParameter)
MacroParameter <- NamedParameter / SimpleParameter
SimpleParameter <- TypeFuncName Type?

ScalarMacroDefinition <- Expression
TableMacroDefinition <- 'TABAELLE' SelectStatementInternal

CommentStatement <- 'KOMMENTAR' 'UF' CommentOnType DottedIdentifier 'ISCH' CommentValue

CommentOnType <-    CommentTable / CommentSequence / CommentFunction / CommentMacroTable / CommentMacro /
                    CommentView / CommentDatabase / CommentIndex / CommentSchema / CommentType / CommentColumn

CommentTable <- 'TABAELLE'
CommentSequence <- 'FOLG'
CommentFunction <- 'FUNKTION'
CommentMacroTable <- 'MAKRO' 'TABAELLE'
CommentMacro <- 'MAKRO'
CommentView <- 'AASICHT'
CommentDatabase <- 'DATEBANK'
CommentIndex <- 'VERZEICHNIS'
CommentSchema <- 'SCHEMA'
CommentType <- 'TYP'
CommentColumn <- 'SPALTE'

CommentValue <- 'NUET' / StringLiteral
AttachStatement <- 'AHAENKE' OrReplace? IfNotExists? Database? DatabasePath AttachAlias? AttachOptions?

Database <- 'DATEBANK'
DatabasePath <- StringLiteral
AttachAlias <- 'ALS' ColId
AttachOptions <- GenericCopyOptionList

DetachStatement <- 'ABHAENKE' Database? IfExists? CatalogName

UseStatement <- 'VERWAENDE' UseTarget

UseTarget <- (CatalogName '.' ReservedSchemaName) / SchemaName / CatalogName

CallStatement <- 'AALUETE' QualifiedTableFunction TableFunctionArguments

