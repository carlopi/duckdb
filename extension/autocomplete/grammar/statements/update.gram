UpdateStatement <- WithClause? 'AKTUALISIERE' UpdateTarget UpdateSetClause FromClause? WhereClause? ReturningClause?

UpdateTarget <- BaseTableSet / BaseTableAliasSet
BaseTableSet <- BaseTableName 'SETZE'
BaseTableAliasSet <- BaseTableName UpdateAlias? 'SETZE'
UpdateAlias <- 'ALS'? ColId
UpdateSetClause <- UpdateSetElementList / UpdateSetTuple
UpdateSetTuple <- Parens(List(ColumnName)) '=' Expression
UpdateSetElementList <- List(UpdateSetElement)
UpdateSetElement <- ColumnName '=' Expression
